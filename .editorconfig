# Editor defaults shared by Rust + TS/TSX + docs.
#
# @see docs/specs/400-dx-tooling/spec.md [FR-8]
# @see docs/specs/400-dx-tooling/design.md [DES-DX-FORMAT]
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{ts,tsx,js,jsx,json,css,html,yml,yaml,md}]
indent_style = space
indent_size = 2

[*.rs]
indent_style = space
indent_size = 4
max_line_length = 100

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
